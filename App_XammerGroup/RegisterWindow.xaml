<Window x:Class="App_XammerGroup.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Регистрация клиента"
        WindowStartupLocation="CenterOwner"
        Width="560"
        Height="760"
        ResizeMode="NoResize"
        Background="#151515">

    <Grid Margin="24">
        <materialDesign:Card Padding="24"
                             UniformCornerRadius="20"
                             Background="#202020">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Регистрация клиента"
                               FontSize="26"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Создание учетной записи для клиента"
                               Margin="0,8,0,20"
                               Foreground="#B5B5B5"
                               HorizontalAlignment="Center"/>

                    <TextBox x:Name="LastNameBox"
                             Margin="0,6"
                             Height="40"
                             Foreground="White"
                             materialDesign:HintAssist.Hint="Фамилия"/>

                    <TextBox x:Name="FirstNameBox"
                             Margin="0,6"
                             Height="40"
                             Foreground="White"
                             materialDesign:HintAssist.Hint="Имя"/>

                    <TextBox x:Name="MiddleNameBox"
                             Margin="0,6"
                             Height="40"
                             Foreground="White"
                             materialDesign:HintAssist.Hint="Отчество (необязательно)"/>

                    <TextBox x:Name="PhoneBox"
                             Margin="0,6"
                             Height="40"
                             Foreground="White"
                             materialDesign:HintAssist.Hint="Телефон"/>

                    <TextBox x:Name="EmailBox"
                             Margin="0,6"
                             Height="40"
                             Foreground="White"
                             materialDesign:HintAssist.Hint="Email"/>

                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,6"
                                 Height="40"
                                 Foreground="White"
                                 materialDesign:HintAssist.Hint="Пароль"/>

                    <PasswordBox x:Name="ConfirmPasswordBox"
                                 Margin="0,6"
                                 Height="40"
                                 Foreground="White"
                                 materialDesign:HintAssist.Hint="Повторите пароль"/>

                    <TextBlock x:Name="ErrorText"
                               Foreground="#FFB00020"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Отмена"
                                Margin="0,0,8,0"
                                Height="42"
                                Click="Cancel_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>

                        <Button Grid.Column="1"
                                Content="Зарегистрироваться"
                                Margin="8,0,0,0"
                                Height="42"
                                Click="Register_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </materialDesign:Card>
    </Grid>
</Window>
