<Page x:Class="App_XammerGroup.ProductsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F5F5">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Продукция"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#202020"/>
            <TextBlock x:Name="ModeText"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#666666"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                             Margin="0,20,0,20"
                             Padding="18"
                             UniformCornerRadius="18"
                             Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Height="42"
                         TextChanged="Filters_Changed"
                         materialDesign:HintAssist.Hint="Поиск по названию или описанию"/>

                <ComboBox x:Name="ActiveFilterBox"
                          Grid.Column="2"
                          Height="42"
                          SelectionChanged="Filters_Changed"
                          materialDesign:HintAssist.Hint="Активность"/>

                <TextBox x:Name="MinPriceBox"
                         Grid.Column="4"
                         Height="42"
                         TextChanged="Filters_Changed"
                         materialDesign:HintAssist.Hint="Цена от"/>

                <TextBox x:Name="MaxPriceBox"
                         Grid.Column="6"
                         Height="42"
                         TextChanged="Filters_Changed"
                         materialDesign:HintAssist.Hint="Цена до"/>

                <ComboBox x:Name="SortBox"
                          Grid.Column="8"
                          Height="42"
                          SelectionChanged="Filters_Changed"
                          materialDesign:HintAssist.Hint="Сортировка"/>
            </Grid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2"
                             Padding="0"
                             UniformCornerRadius="18"
                             Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="ProductsGrid"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          SelectionMode="Single"
                          Margin="0"
                          RowHeight="48">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID"
                                            Width="70"
                                            Binding="{Binding ProductId}"/>
                        <DataGridTextColumn Header="Название"
                                            Width="2.1*"
                                            Binding="{Binding ProductName}"/>
                        <DataGridTextColumn Header="Описание"
                                            Width="2.4*"
                                            Binding="{Binding ShortDescription}"/>
                        <DataGridTextColumn Header="Цена"
                                            Width="120"
                                            Binding="{Binding PriceText}"/>
                        <DataGridTextColumn Header="Статус"
                                            Width="120"
                                            Binding="{Binding ActiveText}"/>
                        <DataGridTextColumn Header="Склад"
                                            Width="170"
                                            Binding="{Binding AvailabilityText}"/>
                        <DataGridTemplateColumn x:Name="CartColumn"
                                                Header="Корзина"
                                                Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Добавить"
                                            Padding="14,6"
                                            Tag="{Binding}"
                                            IsEnabled="{Binding IsAvailable}"
                                            Click="AddToCart_Click"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <DockPanel Grid.Row="1"
                           Margin="18,12,18,18">
                    <TextBlock x:Name="SummaryText"
                               VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="#666666"/>

                    <Button x:Name="OpenCartButton"
                            DockPanel.Dock="Right"
                            Content="Открыть корзину"
                            Padding="16,8"
                            Click="OpenCart_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </DockPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
