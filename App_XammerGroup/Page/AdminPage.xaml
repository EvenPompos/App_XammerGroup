<Page x:Class="App_XammerGroup.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F5F5">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,20">
            <TextBlock Text="Администрирование"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#202020"/>
            <TextBlock Text="Редактирование товаров, состава списания и сотрудников"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#666666"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                             Padding="18"
                             UniformCornerRadius="18"
                             Background="White">
            <TabControl x:Name="AdminTabs">
                <TabItem x:Name="ProductsTab" Header="Товары">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1.2*"/>
                            <RowDefinition Height="16"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DataGrid x:Name="ProductsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="46"
                                  SelectionChanged="ProductsGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Width="70" Binding="{Binding ProductId}"/>
                                <DataGridTextColumn Header="Название" Width="2*" Binding="{Binding ProductName}"/>
                                <DataGridTextColumn Header="Цена" Width="130" Binding="{Binding PriceText}"/>
                                <DataGridTextColumn Header="Статус" Width="120" Binding="{Binding ActiveText}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <materialDesign:Card Grid.Row="2"
                                             Padding="12"
                                             UniformCornerRadius="10"
                                             Background="#FAFAFA">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Состав выбранного товара"
                                           FontWeight="SemiBold"
                                           Foreground="#202020"/>

                                <DataGrid x:Name="ProductMaterialsGrid"
                                          Grid.Row="1"
                                          Margin="0,10,0,10"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          GridLinesVisibility="Horizontal"
                                          RowHeight="40"
                                          SelectionChanged="ProductMaterialsGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Деталь" Width="2*" Binding="{Binding ItemName}"/>
                                        <DataGridTextColumn Header="Кол-во списания" Width="150" Binding="{Binding QuantityText}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="110"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="MaterialItemBox"
                                              Grid.Column="0"
                                              Height="42"
                                              materialDesign:HintAssist.Hint="Деталь со склада"/>

                                    <TextBox x:Name="MaterialQuantityBox"
                                             Grid.Column="2"
                                             Height="42"
                                             materialDesign:HintAssist.Hint="Кол-во"/>

                                    <Button Grid.Column="4"
                                            Content="Сохранить"
                                            Click="SaveMaterial_Click"
                                            Style="{StaticResource MaterialDesignRaisedButton}"/>

                                    <Button Grid.Column="6"
                                            Content="Удалить"
                                            Click="DeleteMaterial_Click"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                                </Grid>
                            </Grid>
                        </materialDesign:Card>

                        <ScrollViewer Grid.Column="2"
                                      Grid.RowSpan="3"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBox x:Name="ProductNameBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Название товара"/>

                                <TextBox x:Name="ProductDescriptionBox"
                                         Margin="0,0,0,10"
                                         Height="150"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         materialDesign:HintAssist.Hint="Подробное описание"/>

                                <TextBox x:Name="ProductPriceBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Цена"/>

                                <TextBox x:Name="ProductImagePathBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Путь к изображению"/>

                                <CheckBox x:Name="ProductIsActiveBox"
                                          Margin="0,0,0,10"
                                          Content="Активный товар"
                                          IsChecked="True"/>

                                <TextBlock x:Name="ProductsErrorText"
                                           Foreground="#FFB00020"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>

                                <Button Content="Добавить товар"
                                        Height="42"
                                        Margin="0,18,0,0"
                                        Click="AddProduct_Click"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                                <Button Content="Сохранить изменения"
                                        Height="42"
                                        Margin="0,10,0,0"
                                        Click="UpdateProduct_Click"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                                <Button Content="Удалить выбранный товар"
                                        Height="42"
                                        Margin="0,10,0,0"
                                        Click="DeleteProduct_Click"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <TabItem x:Name="EmployeesTab" Header="Сотрудники">
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="1.2*"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid x:Name="EmployeesGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  GridLinesVisibility="Horizontal"
                                  RowHeight="46"
                                  SelectionChanged="EmployeesGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Width="70" Binding="{Binding UserId}"/>
                                <DataGridTextColumn Header="Сотрудник" Width="2*" Binding="{Binding FullName}"/>
                                <DataGridTextColumn Header="Email" Width="1.7*" Binding="{Binding Email}"/>
                                <DataGridTextColumn Header="Роль" Width="1.1*" Binding="{Binding RoleName}"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <ScrollViewer Grid.Column="2"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBox x:Name="LastNameBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Фамилия"/>

                                <TextBox x:Name="FirstNameBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Имя"/>

                                <TextBox x:Name="MiddleNameBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Отчество"/>

                                <TextBox x:Name="PhoneBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Телефон"/>

                                <TextBox x:Name="EmailBox"
                                         Margin="0,0,0,10"
                                         Height="42"
                                         materialDesign:HintAssist.Hint="Email"/>

                                <PasswordBox x:Name="PasswordBox"
                                             Margin="0,0,0,10"
                                             Height="42"
                                             materialDesign:HintAssist.Hint="Пароль"/>

                                <ComboBox x:Name="RoleBox"
                                          Margin="0,0,0,10"
                                          Height="42"
                                          materialDesign:HintAssist.Hint="Роль"/>

                                <TextBlock x:Name="EmployeesErrorText"
                                           Foreground="#FFB00020"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>

                                <Button Content="Добавить сотрудника"
                                        Height="42"
                                        Margin="0,18,0,0"
                                        Click="AddEmployee_Click"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                                <Button Content="Сохранить изменения"
                                        Height="42"
                                        Margin="0,10,0,0"
                                        Click="UpdateEmployee_Click"
                                        Style="{StaticResource MaterialDesignRaisedButton}"/>

                                <Button Content="Удалить выбранного сотрудника"
                                        Height="42"
                                        Margin="0,10,0,0"
                                        Click="DeleteEmployee_Click"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </materialDesign:Card>
    </Grid>
</Page>
