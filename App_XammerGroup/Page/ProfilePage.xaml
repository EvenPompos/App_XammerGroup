<Page x:Class="App_XammerGroup.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F5F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Margin="0,0,0,20">
                <TextBlock Text="Профиль"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="#202020"/>
                <TextBlock x:Name="AccessModeText"
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="#666666"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <materialDesign:Card Grid.Column="0"
                                     Padding="24"
                                     UniformCornerRadius="18"
                                     Background="White">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid Width="180" Height="180">
                            <Ellipse x:Name="AvatarEllipse"
                                     Fill="#FFD9D9D9"/>
                            <TextBlock x:Name="AvatarInitialsText"
                                       FontSize="42"
                                       FontWeight="Bold"
                                       Foreground="#5A5A5A"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <TextBlock x:Name="RoleValueText"
                                   Margin="0,18,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"/>

                        <TextBlock x:Name="EmailValueText"
                                   Margin="0,6,0,0"
                                   Foreground="#666666"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="ChangeAvatarButton"
                                Content="Выбрать аватар"
                                Margin="0,18,0,0"
                                Click="ChangeAvatar_Click"
                                Style="{StaticResource MaterialDesignOutlinedButton}"/>
                    </StackPanel>
                </materialDesign:Card>

                <materialDesign:Card Grid.Column="2"
                                     Padding="24"
                                     UniformCornerRadius="18"
                                     Background="White">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="LastNameBox"
                                     Grid.Column="0"
                                     Margin="0,0,10,12"
                                     Height="42"
                                     materialDesign:HintAssist.Hint="Фамилия"/>

                            <TextBox x:Name="FirstNameBox"
                                     Grid.Column="1"
                                     Margin="10,0,0,12"
                                     Height="42"
                                     materialDesign:HintAssist.Hint="Имя"/>
                        </Grid>

                        <TextBox x:Name="MiddleNameBox"
                                 Margin="0,0,0,12"
                                 Height="42"
                                 materialDesign:HintAssist.Hint="Отчество"/>

                        <TextBox x:Name="PhoneBox"
                                 Margin="0,0,0,12"
                                 Height="42"
                                 materialDesign:HintAssist.Hint="Телефон"/>

                        <TextBox x:Name="EmailBox"
                                 Margin="0,0,0,12"
                                 Height="42"
                                 materialDesign:HintAssist.Hint="Email"/>

                        <PasswordBox x:Name="PasswordBox"
                                     Margin="0,0,0,12"
                                     Height="42"
                                     materialDesign:HintAssist.Hint="Пароль"/>

                        <TextBox x:Name="RoleBox"
                                 Margin="0,0,0,12"
                                 Height="42"
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Роль"/>

                        <TextBox x:Name="CreatedDateBox"
                                 Margin="0,0,0,12"
                                 Height="42"
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Дата регистрации"/>

                        <TextBlock x:Name="ErrorText"
                                   Foreground="#FFB00020"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>

                        <Button x:Name="SaveButton"
                                Content="Сохранить изменения"
                                Height="44"
                                Margin="0,18,0,0"
                                Click="Save_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </materialDesign:Card>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
