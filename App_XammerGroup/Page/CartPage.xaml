<Page x:Class="App_XammerGroup.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F5F5">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Корзина"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#202020"/>
            <TextBlock Text="Добавленные товары, количество и оформление заказа"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#666666"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                             Margin="0,20,0,20"
                             Padding="0"
                             UniformCornerRadius="18"
                             Background="White">
            <DataGrid x:Name="CartGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      RowHeight="48"
                      Margin="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID"
                                        Width="70"
                                        Binding="{Binding ProductId}"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Название"
                                        Width="2*"
                                        Binding="{Binding ProductName}"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Цена"
                                        Width="130"
                                        Binding="{Binding PriceText}"
                                        IsReadOnly="True"/>
                    <DataGridTextColumn Header="Количество"
                                        Width="140"
                                        Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"/>
                    <DataGridTextColumn Header="Сумма"
                                        Width="150"
                                        Binding="{Binding TotalText}"
                                        IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Удалить"
                                            Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Убрать"
                                        Tag="{Binding}"
                                        Click="Remove_Click"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </materialDesign:Card>

        <materialDesign:Card Grid.Row="2"
                             Padding="18"
                             UniformCornerRadius="18"
                             Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Комментарий к заказу"
                               FontWeight="SemiBold"
                               Foreground="#202020"/>
                    <TextBox x:Name="CommentBox"
                             Margin="0,10,0,0"
                             Height="90"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             materialDesign:HintAssist.Hint="Комментарий или пожелания"/>

                    <TextBlock x:Name="ErrorText"
                               Margin="0,10,0,0"
                               Foreground="#FFB00020"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock x:Name="SummaryText"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#202020"/>

                    <Button Content="Пересчитать"
                            Height="42"
                            Margin="0,16,0,0"
                            Click="Refresh_Click"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>

                    <Button Content="Оформить заказ"
                            Height="44"
                            Margin="0,12,0,0"
                            Click="Checkout_Click"
                            Style="{StaticResource MaterialDesignRaisedButton}"/>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
