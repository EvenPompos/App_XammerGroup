<Page x:Class="App_XammerGroup.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      Background="#F5F5F5">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Заказы"
                       FontSize="30"
                       FontWeight="SemiBold"
                       Foreground="#202020"/>
            <TextBlock x:Name="ModeText"
                       Margin="0,6,0,0"
                       FontSize="14"
                       Foreground="#666666"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <materialDesign:Card Grid.Row="1"
                             Margin="0,20,0,20"
                             Padding="18"
                             UniformCornerRadius="18"
                             Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="1.2*"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox"
                         Grid.Column="0"
                         Height="42"
                         TextChanged="Filters_Changed"
                         materialDesign:HintAssist.Hint="Поиск по клиенту, менеджеру, описанию или комментарию"/>

                <ComboBox x:Name="StatusFilterBox"
                          Grid.Column="2"
                          Height="42"
                          SelectionChanged="Filters_Changed"
                          materialDesign:HintAssist.Hint="Статус"/>

                <ComboBox x:Name="SortBox"
                          Grid.Column="4"
                          Height="42"
                          SelectionChanged="Filters_Changed"
                          materialDesign:HintAssist.Hint="Сортировка"/>
            </Grid>
        </materialDesign:Card>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="1.3*"/>
            </Grid.ColumnDefinitions>

            <materialDesign:Card Grid.Column="0"
                                 Padding="0"
                                 UniformCornerRadius="18"
                                 Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="OrdersGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              RowHeight="48"
                              SelectionChanged="OrdersGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№"
                                                Width="70"
                                                Binding="{Binding OrderId}"/>
                            <DataGridTextColumn Header="Клиент"
                                                Width="1.6*"
                                                Binding="{Binding ClientName}"/>
                            <DataGridTextColumn Header="Менеджер"
                                                Width="1.4*"
                                                Binding="{Binding ManagerName}"/>
                            <DataGridTextColumn Header="Статус"
                                                Width="1.1*"
                                                Binding="{Binding StatusName}"/>
                            <DataGridTextColumn Header="Создан"
                                                Width="125"
                                                Binding="{Binding CreatedDateText}"/>
                            <DataGridTextColumn Header="Срок"
                                                Width="125"
                                                Binding="{Binding DeadlineDateText}"/>
                            <DataGridTextColumn Header="Сумма"
                                                Width="120"
                                                Binding="{Binding TotalAmountText}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="SummaryText"
                               Grid.Row="1"
                               Margin="18,12,18,18"
                               FontSize="14"
                               Foreground="#666666"/>
                </Grid>
            </materialDesign:Card>

            <materialDesign:Card Grid.Column="2"
                                 Padding="24"
                                 UniformCornerRadius="18"
                                 Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Карточка заказа"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#202020"/>

                        <TextBlock x:Name="SelectionHintText"
                                   Margin="0,10,0,0"
                                   Foreground="#666666"
                                   TextWrapping="Wrap"/>

                        <TextBox x:Name="OrderNumberBox"
                                 Margin="0,16,0,10"
                                 Height="42"
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Номер заказа"/>

                        <TextBox x:Name="ClientBox"
                                 Margin="0,0,0,10"
                                 Height="42"
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Клиент"/>

                        <TextBox x:Name="AmountBox"
                                 Margin="0,0,0,10"
                                 Height="42"
                                 IsReadOnly="True"
                                 materialDesign:HintAssist.Hint="Сумма"/>

                        <ComboBox x:Name="ManagerBox"
                                  Margin="0,0,0,10"
                                  Height="42"
                                  materialDesign:HintAssist.Hint="Менеджер"/>

                        <ComboBox x:Name="StatusBox"
                                  Margin="0,0,0,10"
                                  Height="42"
                                  materialDesign:HintAssist.Hint="Статус"/>

                        <DatePicker x:Name="DeadlinePicker"
                                    Margin="0,0,0,10"
                                    Height="42"/>

                        <TextBox x:Name="DescriptionBox"
                                 Margin="0,0,0,10"
                                 Height="88"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 materialDesign:HintAssist.Hint="Описание"/>

                        <TextBox x:Name="CommentBox"
                                 Margin="0,0,0,10"
                                 Height="88"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 materialDesign:HintAssist.Hint="Комментарий"/>

                        <TextBlock x:Name="ErrorText"
                                   Margin="0,6,0,0"
                                   Foreground="#FFB00020"
                                   TextWrapping="Wrap"/>

                        <Button x:Name="SaveButton"
                                Content="Сохранить изменения"
                                Height="44"
                                Margin="0,18,0,0"
                                Click="Save_Click"
                                Style="{StaticResource MaterialDesignRaisedButton}"/>
                    </StackPanel>
                </ScrollViewer>
            </materialDesign:Card>
        </Grid>
    </Grid>
</Page>
