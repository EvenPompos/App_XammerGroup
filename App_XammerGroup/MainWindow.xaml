<Window x:Class="App_XammerGroup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Xammer Group"
        WindowState="Maximized"
        Background="{DynamicResource MaterialDesignPaper}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid Background="#1A1A1A">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="20">
                <TextBlock Text="XAMMER GROUP"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Система заявок"
                           Foreground="Gray"
                           FontSize="12"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="10">
                <Button x:Name="ProfileButton"
                        Click="Profile_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountCircle" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Профиль"/>
                    </StackPanel>
                </Button>

                <Button x:Name="OrdersButton"
                        Click="Orders_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ClipboardText" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Заказы"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ProductsButton"
                        Click="Products_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PackageVariantClosed" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Продукция"/>
                    </StackPanel>
                </Button>

                <Button x:Name="CartButton"
                        Click="Cart_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="CartOutline" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Корзина"/>
                    </StackPanel>
                </Button>

                <Button x:Name="EmployeesButton"
                        Click="Employees_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountTie" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Сотрудники"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ReportsButton"
                        Click="Reports_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileChartOutline" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="PDF-отчеты"/>
                    </StackPanel>
                </Button>

                <Button x:Name="InventoryButton"
                        Click="Inventory_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Warehouse" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Склад"/>
                    </StackPanel>
                </Button>

                <Button x:Name="AdminButton"
                        Click="Admin_Click"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Foreground="White"
                        HorizontalContentAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Cog" Width="22" Margin="0,0,10,0"/>
                        <TextBlock Text="Администрирование"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Button Grid.Row="2"
                    Click="Logout_Click"
                    Style="{DynamicResource MaterialDesignFlatButton}"
                    Foreground="White"
                    HorizontalContentAlignment="Left"
                    Margin="10">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Logout" Width="22" Margin="0,0,10,0"/>
                    <TextBlock Text="Выход"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <materialDesign:ColorZone Mode="PrimaryDark" Padding="10">
                <DockPanel>
                    <StackPanel>
                        <TextBlock Text="Система управления заявками"
                                   Foreground="White"
                                   FontSize="18"/>
                        <TextBlock x:Name="RoleText"
                                   Foreground="#FFD0D0D0"
                                   FontSize="12"/>
                    </StackPanel>

                    <TextBlock x:Name="UserNameText"
                               Foreground="White"
                               DockPanel.Dock="Right"
                               Margin="10 0 0 0"
                               VerticalAlignment="Center"/>
                </DockPanel>
            </materialDesign:ColorZone>

            <Frame x:Name="MainFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"/>
        </Grid>
    </Grid>
</Window>
